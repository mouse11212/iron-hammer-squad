*.env
.env
.env.*
*.pem
*.key
*token*
*secret*
.npmrc

# ── 系统 / 编辑器 ──
.DS_Store
*.log
.claude/settings.local.json

# ── OpenSpec 运行缓存(如有) ──
.openspec-cache/
