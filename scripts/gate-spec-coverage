#!/bin/sh
# spec-coverage 门:暂存改动若含能力源(pipeline/*/src/**/*.ts)却无对应进行中 OpenSpec change → 阻断提交。
# 由 scripts/install-hooks.sh 装进 .git/hooks/pre-commit;判定逻辑单一真相 = pipeline/driver/src/spec-coverage.ts。
set -e
cd "$(git rev-parse --show-toplevel)/pipeline/driver"
exec npx tsx src/bin-spec-coverage.ts "$@"
