{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "testRunner": "vitest",
  "mutate": [
    "src/parse.ts",
    "src/filterToday.ts",
    "src/render.ts",
    "src/aggregate.ts",
    "src/canonicalizeUrl.ts",
    "src/truncateTitle.ts",
    "src/clampPercent.ts"
  ],
  "reporters": [
    "clear-text",
    "progress"
  ],
  "coverageAnalysis": "perTest",
  "timeoutMS": 60000,
  "thresholds": {
    "high": 95,
    "low": 90,
    "break": 90
  }
}